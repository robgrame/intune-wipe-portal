@inherits LayoutComponentBase

<NavMenu />

<main>
    <article class="content px-4 py-3">
        @Body
    </article>
</main>

<footer class="portal-footer text-center text-muted small py-3 border-top mt-auto">
    <span class="me-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 96 96" class="me-1" style="vertical-align: -2px;">
            <path fill="#0078D4" d="M0 33.3L44.6 28l.1 43.6-44.6.3zm44.6 42.5l.1 43.6L0 114.6V76zm5-47.5L95.9 22v46.7l-46.3.4zm46.3 47l.1 46.4-46.3-6.5-.1-40z"/>
        </svg>
        Running on Azure
    </span>
    <span class="me-3">
        Made with <span class="text-danger">&#10084;</span> for IT Admins
    </span>
    <span>
        Build @(typeof(Program).Assembly.GetName().Version?.ToString() ?? "dev")
    </span>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
