@inherits LayoutComponentBase
@using System.Reflection

<NavMenu />

<main>
    <article class="content px-4 py-3">
        @Body
    </article>
</main>

<footer class="modern-footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-links">
                <a href="">Dashboard</a>
                <a href="schedule">Schedule</a>
                <a href="configuration">Configurazione</a>
                <a href="audit">Audit</a>
                <a href="about">About</a>
            </div>
            <p class="mb-1">
                &copy; @DateTime.UtcNow.Year - Intune Device Actions -
                <small class="text-muted">
                    <i class="bi bi-code-slash me-1"></i>
                    <span title="Application version">v@(GetVersion())</span>
                </small>
            </p>
            <span class="d-flex align-items-center gap-3 flex-wrap justify-content-center mb-2">
                <span title="Hosted on Microsoft Azure">
                    <img src="images/Azure-A.svg" alt="Azure" class="footer-azure-logo me-1" />Running on Azure
                </span>
                <span><i class="bi bi-heart-fill me-1 text-danger"></i>Fatto con passione per gli IT Admin</span>
            </span>
        </div>
    </div>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static string GetVersion()
    {
        var assembly = Assembly.GetEntryAssembly() ?? Assembly.GetExecutingAssembly();
        var infoAttr = assembly.GetCustomAttribute<AssemblyInformationalVersionAttribute>();
        return infoAttr?.InformationalVersion ?? assembly.GetName().Version?.ToString() ?? "dev";
    }
}
