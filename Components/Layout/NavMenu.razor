@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<nav class="navbar navbar-expand-md navbar-dark navbar-brand-green sticky-top shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="">
            <img src="favicon-32.png" alt="" width="28" height="28" class="brand-logo" />
            <span>Intune Device Actions</span>
            <span class="brand-sub d-none d-sm-inline">Observability</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#topNav" aria-controls="topNav"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="topNav">
            <ul class="navbar-nav me-auto mb-2 mb-md-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Dashboard</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="cruscotto" data-enhance-nav="false">Cruscotto</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="monitoraggio">Monitoraggio</NavLink>
                </li>
                <AuthorizeView Policy="CanScheduleWrite">
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="schedule">Schedule</NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="configuration">Configurazione</NavLink>
                        </li>
                    </Authorized>
                </AuthorizeView>
                <li class="nav-item">
                    <NavLink class="nav-link" href="audit">Audit</NavLink>
                </li>
                @if (GrafanaLinks.Count > 0)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">Grafana</a>
                        <ul class="dropdown-menu dropdown-menu-dark">
                            @foreach (var link in GrafanaLinks)
                            {
                                <li>
                                    <a class="dropdown-item" href="@link.Url"
                                       target="_blank" rel="noopener noreferrer">
                                        @link.Title
                                        <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }
                <li class="nav-item">
                    <NavLink class="nav-link" href="about">About</NavLink>
                </li>
            </ul>
            <AuthorizeView>
                <Authorized>
                    <span class="navbar-text text-light me-3 small">
                        <i class="bi bi-person-circle"></i>
                        @context.User.Identity?.Name
                    </span>
                    <button type="button" class="btn btn-sm btn-outline-light me-2 theme-toggle"
                            title="Cambia tema chiaro/scuro" aria-label="Cambia tema chiaro/scuro"
                            onclick="window.portalTheme.toggle()">
                        <i class="bi bi-circle-half"></i>
                    </button>
                    <a class="btn btn-sm btn-outline-light"
                       href="MicrosoftIdentity/Account/SignOut">Esci</a>
                </Authorized>
                <NotAuthorized>
                    <button type="button" class="btn btn-sm btn-outline-light me-2 theme-toggle"
                            title="Cambia tema chiaro/scuro" aria-label="Cambia tema chiaro/scuro"
                            onclick="window.portalTheme.toggle()">
                        <i class="bi bi-circle-half"></i>
                    </button>
                    <a class="btn btn-sm btn-outline-light"
                       href="MicrosoftIdentity/Account/SignIn">Accedi</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

@code {
    private sealed record GrafanaLink(string Title, string Url);

    private List<GrafanaLink> GrafanaLinks { get; set; } = new();

    protected override void OnInitialized()
    {
        var section = Configuration.GetSection("Grafana");
        var baseUrl = section["BaseUrl"]?.TrimEnd('/');
        if (string.IsNullOrWhiteSpace(baseUrl))
        {
            return;
        }

        var kiosk = section.GetValue("Kiosk", true);
        var query = kiosk ? "?kiosk" : string.Empty;

        foreach (var dash in section.GetSection("Dashboards").GetChildren())
        {
            var title = dash["Title"];
            var uid = dash["Uid"];
            if (string.IsNullOrWhiteSpace(title) || string.IsNullOrWhiteSpace(uid))
            {
                continue;
            }
            GrafanaLinks.Add(new GrafanaLink(title, $"{baseUrl}/d/{uid}{query}"));
        }
    }
}
