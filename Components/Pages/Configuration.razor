@page "/configuration"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "CanScheduleWrite")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IntuneWipePortal.Services.AppConfigManagementService AppConfig
@inject DeviceLookupService DeviceLookup
@inject ILogger<Configuration> Logger

<PageTitle>Configurazione</PageTitle>

<h1 class="mb-3">Configurazione App</h1>
<p class="text-muted">
    Modifica le impostazioni operative. Le modifiche vengono applicate entro 30 secondi (hot-reload).
    <i class="bi bi-info-circle text-primary" role="img" aria-label="info"
       title="Le impostazioni vengono scritte su Azure App Configuration. Un Sentinel bump notifica tutti i Function App entro 30 secondi senza restart."></i>
</p>

@if (_loading)
{
    <p><em>Caricamento configurazione…</em></p>
}
else
{
    <form @onsubmit="SaveAsync">
        <!-- Certificati -->
        <fieldset class="mb-4">
            <legend>🔐 Certificati CA</legend>
            <p class="text-muted small">
                Carica i file <code>.cer</code> delle CA fidate. Il sistema determina automaticamente se si tratta di una Root CA
                (Subject = Issuer) o una Subordinate CA ed estrae Subject, Thumbprint e contenuto Base64.
            </p>

            <div class="mb-3">
                <label class="form-label fw-bold">Carica certificati (.cer / .crt)</label>
                <InputFile OnChange="OnCertFilesSelected" multiple accept=".cer,.crt"
                           class="form-control" />
            </div>

            @if (_certError is not null)
            {
                <div class="alert alert-warning py-1">@_certError</div>
            }

            @if (_parsedCerts.Count > 0)
            {
                <table class="table table-sm table-bordered align-middle mb-3">
                    <thead class="table-light">
                        <tr>
                            <th>Tipo</th>
                            <th>Subject</th>
                            <th>Thumbprint (SHA1)</th>
                            <th>Scadenza</th>
                            <th style="width:50px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cert in _parsedCerts)
                        {
                            <tr class="@(cert.IsExpired ? "table-danger" : "")">
                                <td>
                                    <span class="badge bg-@(cert.IsRoot ? "dark" : "secondary")">
                                        @(cert.IsRoot ? "Root CA" : "Sub CA")
                                    </span>
                                </td>
                                <td class="small">@cert.Subject</td>
                                <td><code class="small">@cert.Thumbprint</code></td>
                                <td class="small @(cert.IsExpired ? "text-danger fw-bold" : "")">
                                    @cert.NotAfter.ToString("yyyy-MM-dd")
                                    @if (cert.IsExpired) { <span> ⚠️</span> }
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveCert(cert)"
                                            title="Rimuovi">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-light border small py-2">
                    <i class="bi bi-info-circle"></i> Nessun certificato CA configurato. Carica almeno una Root CA.
                </div>
            }

            <div class="mb-3 form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="chkCrl" @bind="_checkRevocation" />
                <label class="form-check-label" for="chkCrl">
                    Verifica CRL/OCSP
                    <i class="bi bi-info-circle text-muted ms-1" role="img"
                       title="Abilita la verifica dello stato di revoca dei certificati client. Quando attivo, il sistema controlla la CRL (Certificate Revocation List) o OCSP per accertarsi che il certificato non sia stato revocato."></i>
                </label>
            </div>

            @if (_checkRevocation)
            {
                <div class="mb-3">
                    <label class="form-label">
                        Modalità revoca
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Online: scarica CRL/OCSP in tempo reale (richiede connettività). Offline: usa solo CRL già in cache locale. NoCheck: disabilita completamente la verifica (non consigliato in produzione)."></i>
                    </label>
                    <select class="form-select" @bind="_revocationMode">
                        <option value="Online">Online (scarica CRL/OCSP)</option>
                        <option value="Offline">Offline (cache locale)</option>
                        <option value="NoCheck">NoCheck (disabilitato)</option>
                    </select>
                </div>
            }
        </fieldset>

        <!-- General -->
        <fieldset class="mb-4">
            <legend>⚙️ Impostazioni generali</legend>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Action Types abilitati
                    <i class="bi bi-info-circle text-muted ms-1" role="img"
                       title="Lista CSV dei tipi di azione che l'API accetta. Le richieste con actionType non in lista vengono rifiutate con 400 Bad Request. Valori supportati: wipe, autopilot, bitlocker, rename."></i>
                </label>
                <input type="text" class="form-control" @bind="_allowedTypes" placeholder="wipe,autopilot,bitlocker,rename" />
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Max azioni/device/giorno
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Numero massimo di azioni consentite per lo stesso device in 24 ore. Protegge da loop accidentali o abuso. Superato il limite, le richieste vengono rifiutate finché non scade la finestra."></i>
                    </label>
                    <input type="number" class="form-control" @bind="_maxActionsPerDay" min="1" max="100" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Grazia rearm (ore)
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Ore dopo le quali un ledger entry bloccato diventa eleggibile per rearm automatico. Se un device ha raggiunto il limite giornaliero e questa finestra è trascorsa, il contatore viene resettato."></i>
                    </label>
                    <input type="number" class="form-control" @bind="_rearmGraceHours" min="1" max="720" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Anti-replay skew (sec)
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Finestra temporale massima (in secondi) entro cui il timestamp della richiesta client è considerato valido. Protegge da attacchi replay: richieste con timestamp più vecchio di N secondi vengono rifiutate con 401."></i>
                    </label>
                    <input type="number" class="form-control" @bind="_maxTimestampSkew" min="30" max="3600" />
                </div>
            </div>

            <div class="mb-3 form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="chkRearm" @bind="_allowForceRearm" />
                <label class="form-check-label" for="chkRearm">
                    Consenti rearm manuale ledger
                    <i class="bi bi-info-circle text-muted ms-1" role="img"
                       title="Se attivo, gli operatori possono forzare il reset del contatore idempotency per un device specifico dal portale (Dashboard > Reset Ledger). Utile per sbloccare device in situazioni eccezionali."></i>
                </label>
            </div>

            <div class="mb-3 form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="chkAdminApi" @bind="_adminApiEnabled" />
                <label class="form-check-label" for="chkAdminApi">
                    API Admin Ledger abilitata
                    <i class="bi bi-info-circle text-muted ms-1" role="img"
                       title="Abilita gli endpoint HTTP admin per la gestione del ledger idempotency (GET/RESET). Quando disabilitato, gli endpoint ritornano 404 anche per utenti autenticati."></i>
                </label>
            </div>
        </fieldset>

        <!-- Wipe -->
        <fieldset class="mb-4">
            <legend>🗑️ Wipe</legend>

            <div class="row">
                <div class="col-md-6 mb-3 form-check form-switch ms-2">
                    <input class="form-check-input" type="checkbox" role="switch" id="chkKeepEnroll" @bind="_keepEnrollmentData" />
                    <label class="form-check-label" for="chkKeepEnroll">
                        Mantieni dati enrollment
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Se attivo, il wipe preserva i dati di enrollment Intune sul device. Il device rimane registrato in Intune dopo il wipe e può ri-enrollarsi automaticamente al prossimo avvio senza intervento manuale."></i>
                    </label>
                </div>
                <div class="col-md-6 mb-3 form-check form-switch ms-2">
                    <input class="form-check-input" type="checkbox" role="switch" id="chkKeepUser" @bind="_keepUserData" />
                    <label class="form-check-label" for="chkKeepUser">
                        Mantieni dati utente
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Se attivo, il wipe preserva la cartella del profilo utente (C:\\Users\\<user>) sul device. I dati personali e le configurazioni dell'utente non vengono eliminati."></i>
                    </label>
                </div>
            </div>
        </fieldset>

        <!-- BitLocker -->
        <fieldset class="mb-4">
            <legend>🔑 BitLocker</legend>
            <p class="text-muted small">Nessuna impostazione aggiuntiva specifica. Il gate di gruppo viene configurato nella sezione sottostante.</p>
        </fieldset>

        <!-- Capability Gate Groups -->
        <fieldset class="mb-4">
            <legend>🛡️ Gate gruppi per capability</legend>
            <p class="text-muted small">
                Associa un gruppo Entra a ciascuna capability. Solo i device appartenenti al gruppo possono ricevere l'azione corrispondente.
                Lasciare vuoto per disabilitare il gate (qualsiasi device accettato).
            </p>

            <table class="table table-bordered table-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:140px">Capability</th>
                        <th>Gruppo</th>
                        <th style="width:320px">Group ID</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gate in _capabilityGates)
                    {
                        <tr>
                            <td><code>@gate.Capability</code></td>
                            <td class="position-relative">
                                <input class="form-control form-control-sm" value="@gate.GroupName"
                                       @oninput="(e) => OnGateGroupSearch(gate, e)"
                                       @onfocusout="() => OnGateGroupFocusOut(gate)"
                                       placeholder="Cerca gruppo..." autocomplete="off" />
                                @if (gate.ShowDropdown && gate.SearchResults.Count > 0)
                                {
                                    <div class="list-group position-absolute w-100 shadow" style="z-index:1050; max-height:180px; overflow-y:auto;">
                                        @foreach (var g in gate.SearchResults)
                                        {
                                            <button type="button" class="list-group-item list-group-item-action py-1"
                                                    @onmousedown="() => SelectGateGroup(gate, g)" @onmousedown:preventDefault>
                                                <strong>@g.DisplayName</strong>
                                                @if (!string.IsNullOrEmpty(g.Description))
                                                {
                                                    <span class="text-muted small ms-2">@g.Description</span>
                                                }
                                                <br /><code class="small text-secondary">@g.GroupId</code>
                                            </button>
                                        }
                                    </div>
                                }
                            </td>
                            <td><code class="small text-secondary">@gate.GroupId</code></td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(gate.GroupId))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ClearGateGroup(gate)"
                                            title="Rimuovi associazione">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </fieldset>

        <!-- Monitoring -->
        <fieldset class="mb-4">
            <legend>📊 Monitoring</legend>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Finestra poller stato (ore)
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Il poller verifica su Microsoft Graph lo stato delle azioni inviate. Questa impostazione definisce quante ore indietro il poller considera le azioni 'attive'. Azioni più vecchie vengono ignorate."></i>
                    </label>
                    <input type="number" class="form-control" @bind="_pollMaxAgeHours" min="1" max="168" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Frequenza poller (CRON)
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Espressione CRON a 6 campi (sec min ore giorno mese dow) che definisce la frequenza con cui il poller interroga Graph per lo stato delle azioni. Default: ogni 5 secondi. Richiede restart dell'app."></i>
                    </label>
                    <input type="text" class="form-control" @bind="_pollerCron" placeholder="*/5 * * * * *" />
                </div>
                <div class="col-md-4 mb-3 form-check form-switch mt-4 ms-2">
                    <input class="form-check-input" type="checkbox" role="switch" id="chkEg" @bind="_eventGridEnabled" />
                    <label class="form-check-label" for="chkEg">
                        Event Grid audit stream
                        <i class="bi bi-info-circle text-muted ms-1" role="img"
                           title="Quando attivo, gli eventi di audit (azione inviata, completata, fallita) vengono pubblicati anche su Azure Event Grid. Il portale li usa per gli aggiornamenti real-time del cruscotto via SignalR."></i>
                    </label>
                </div>
            </div>
        </fieldset>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@_saving">
                @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Salva configurazione
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="LoadAsync">Annulla</button>
        </div>

        @if (_saved)
        {
            <div class="alert alert-success mt-3" role="alert">
                ✅ Configurazione salvata. Le modifiche saranno attive entro 30 secondi.
            </div>
        }
        @if (_error is not null)
        {
            <div class="alert alert-danger mt-3" role="alert">
                ❌ Errore: @_error
            </div>
        }
    </form>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private bool _saved;
    private string? _error;

    // Certificati
    private List<ParsedCert> _parsedCerts = new();
    private string? _certError;
    private bool _checkRevocation;
    private string _revocationMode = "Online";

    // General
    private string _allowedTypes = "wipe";
    private int _maxActionsPerDay = 5;
    private int _rearmGraceHours = 48;
    private int _maxTimestampSkew = 300;
    private bool _allowForceRearm = true;
    private bool _adminApiEnabled = true;

    // Wipe
    private bool _keepEnrollmentData;
    private bool _keepUserData;

    // Capability gate groups
    private List<CapabilityGateRow> _capabilityGates = new();

    private static readonly string[] GatedCapabilities = ["wipe", "bitlocker", "autopilot", "rename"];

    // Monitoring
    private int _pollMaxAgeHours = 24;
    private string _pollerCron = "*/5 * * * * *";
    private bool _eventGridEnabled = true;

    private static readonly string[] Keys = [
        "ClientCert:TrustedCaSubjects",
        "ClientCert:TrustedCaThumbprints",
        "ClientCert:TrustedRootCertificates",
        "ClientCert:TrustedIntermediateCertificates",
        "ClientCert:CheckRevocation",
        "ClientCert:RevocationMode",
        "Actions:AllowedTypes",
        "Idempotency:MaxActionsPerDevicePerDay",
        "Idempotency:RearmGracePeriodHours",
        "Idempotency:AllowForceRearm",
        "Idempotency:AdminApiEnabled",
        "Replay:MaxTimestampSkewSeconds",
        "Wipe:AllowedGroupId",
        "Wipe:AllowedGroupName",
        "Wipe:KeepEnrollmentData",
        "Wipe:KeepUserData",
        "BitLocker:AllowedGroupId",
        "BitLocker:AllowedGroupName",
        "Autopilot:AllowedGroupId",
        "Autopilot:AllowedGroupName",
        "Rename:AllowedGroupId",
        "Rename:AllowedGroupName",
        "ActionStatus:PollMaxAgeHours",
        "ActionStatusPoller:CronExpression",
        "EventGrid:Enabled",
    ];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _saved = false;
        _error = null;
        try
        {
            var values = await AppConfig.GetManyAsync(Keys);

            // Reconstruct parsed certs from stored Base64
            _parsedCerts = new List<ParsedCert>();
            var rootB64 = values.GetValueOrDefault("ClientCert:TrustedRootCertificates") ?? "";
            var subB64 = values.GetValueOrDefault("ClientCert:TrustedIntermediateCertificates") ?? "";
            foreach (var b64 in rootB64.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                TryAddCertFromBase64(b64, forceRoot: true);
            foreach (var b64 in subB64.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                TryAddCertFromBase64(b64, forceRoot: false);
            _checkRevocation = bool.TryParse(values.GetValueOrDefault("ClientCert:CheckRevocation"), out var cr) && cr;
            _revocationMode = values.GetValueOrDefault("ClientCert:RevocationMode") ?? "Online";

            _allowedTypes = values.GetValueOrDefault("Actions:AllowedTypes") ?? "wipe";
            _maxActionsPerDay = int.TryParse(values.GetValueOrDefault("Idempotency:MaxActionsPerDevicePerDay"), out var m) ? m : 5;
            _rearmGraceHours = int.TryParse(values.GetValueOrDefault("Idempotency:RearmGracePeriodHours"), out var rh) ? rh : 48;
            _allowForceRearm = !bool.TryParse(values.GetValueOrDefault("Idempotency:AllowForceRearm"), out var fr) || fr;
            _adminApiEnabled = !bool.TryParse(values.GetValueOrDefault("Idempotency:AdminApiEnabled"), out var aa) || aa;
            _maxTimestampSkew = int.TryParse(values.GetValueOrDefault("Replay:MaxTimestampSkewSeconds"), out var ts) ? ts : 300;

            _capabilityGates = GatedCapabilities.Select(cap =>
            {
                var keyPrefix = cap switch { "bitlocker" => "BitLocker", "autopilot" => "Autopilot", "rename" => "Rename", _ => "Wipe" };
                return new CapabilityGateRow
                {
                    Capability = cap,
                    GroupId = values.GetValueOrDefault($"{keyPrefix}:AllowedGroupId") ?? "",
                    GroupName = values.GetValueOrDefault($"{keyPrefix}:AllowedGroupName") ?? "",
                };
            }).ToList();
            _keepEnrollmentData = bool.TryParse(values.GetValueOrDefault("Wipe:KeepEnrollmentData"), out var ke) && ke;
            _keepUserData = bool.TryParse(values.GetValueOrDefault("Wipe:KeepUserData"), out var ku) && ku;

            _pollMaxAgeHours = int.TryParse(values.GetValueOrDefault("ActionStatus:PollMaxAgeHours"), out var pa) ? pa : 24;
            _pollerCron = values.GetValueOrDefault("ActionStatusPoller:CronExpression") ?? "*/5 * * * * *";
            _eventGridEnabled = !bool.TryParse(values.GetValueOrDefault("EventGrid:Enabled"), out var eg) || eg;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to load configuration from App Config");
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _saved = false;
        _error = null;
        try
        {
            var roots = _parsedCerts.Where(c => c.IsRoot).ToList();
            var subs = _parsedCerts.Where(c => !c.IsRoot).ToList();
            var allCerts = _parsedCerts;

            var settings = new Dictionary<string, string>
            {
                ["ClientCert:TrustedCaSubjects"] = string.Join("|", allCerts.Select(c => c.Subject)),
                ["ClientCert:TrustedCaThumbprints"] = string.Join(",", allCerts.Select(c => c.Thumbprint)),
                ["ClientCert:TrustedRootCertificates"] = string.Join(",", roots.Select(c => c.Base64)),
                ["ClientCert:TrustedIntermediateCertificates"] = string.Join(",", subs.Select(c => c.Base64)),
                ["ClientCert:CheckRevocation"] = _checkRevocation.ToString().ToLower(),
                ["ClientCert:RevocationMode"] = _revocationMode,
                ["Actions:AllowedTypes"] = _allowedTypes,
                ["Idempotency:MaxActionsPerDevicePerDay"] = _maxActionsPerDay.ToString(),
                ["Idempotency:RearmGracePeriodHours"] = _rearmGraceHours.ToString(),
                ["Idempotency:AllowForceRearm"] = _allowForceRearm.ToString().ToLower(),
                ["Idempotency:AdminApiEnabled"] = _adminApiEnabled.ToString().ToLower(),
                ["Replay:MaxTimestampSkewSeconds"] = _maxTimestampSkew.ToString(),
                ["Wipe:AllowedGroupId"] = _capabilityGates.FirstOrDefault(g => g.Capability == "wipe")?.GroupId ?? "",
                ["Wipe:AllowedGroupName"] = _capabilityGates.FirstOrDefault(g => g.Capability == "wipe")?.GroupName ?? "",
                ["Wipe:KeepEnrollmentData"] = _keepEnrollmentData.ToString().ToLower(),
                ["Wipe:KeepUserData"] = _keepUserData.ToString().ToLower(),
                ["BitLocker:AllowedGroupId"] = _capabilityGates.FirstOrDefault(g => g.Capability == "bitlocker")?.GroupId ?? "",
                ["BitLocker:AllowedGroupName"] = _capabilityGates.FirstOrDefault(g => g.Capability == "bitlocker")?.GroupName ?? "",
                ["Autopilot:AllowedGroupId"] = _capabilityGates.FirstOrDefault(g => g.Capability == "autopilot")?.GroupId ?? "",
                ["Autopilot:AllowedGroupName"] = _capabilityGates.FirstOrDefault(g => g.Capability == "autopilot")?.GroupName ?? "",
                ["Rename:AllowedGroupId"] = _capabilityGates.FirstOrDefault(g => g.Capability == "rename")?.GroupId ?? "",
                ["Rename:AllowedGroupName"] = _capabilityGates.FirstOrDefault(g => g.Capability == "rename")?.GroupName ?? "",
                ["ActionStatus:PollMaxAgeHours"] = _pollMaxAgeHours.ToString(),
                ["ActionStatusPoller:CronExpression"] = _pollerCron,
                ["EventGrid:Enabled"] = _eventGridEnabled.ToString().ToLower(),
            };
            await AppConfig.SetManyAsync(settings);
            _saved = true;
            Logger.LogInformation("Configuration saved by operator");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to save configuration");
        }
        _saving = true;
        _saving = false;
    }

    // ---- Capability gate group typeahead ---------------------------------

    private CancellationTokenSource? _gateSearchCts;

    private async Task OnGateGroupSearch(CapabilityGateRow gate, ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        gate.GroupName = value;

        _gateSearchCts?.Cancel();
        _gateSearchCts = new CancellationTokenSource();
        var token = _gateSearchCts.Token;

        if (value.Length < 2)
        {
            gate.SearchResults.Clear();
            gate.ShowDropdown = false;
            return;
        }

        try { await Task.Delay(300, token); }
        catch (TaskCanceledException) { return; }

        try
        {
            var results = await DeviceLookup.SearchGroupsAsync(value, 10, token);
            if (!token.IsCancellationRequested)
            {
                gate.SearchResults = results.ToList();
                gate.ShowDropdown = gate.SearchResults.Count > 0;
            }
        }
        catch (TaskCanceledException) { }
    }

    private void SelectGateGroup(CapabilityGateRow gate, GroupLookupResult group)
    {
        gate.GroupId = group.GroupId;
        gate.GroupName = group.DisplayName;
        gate.SearchResults.Clear();
        gate.ShowDropdown = false;
    }

    private void ClearGateGroup(CapabilityGateRow gate)
    {
        gate.GroupId = "";
        gate.GroupName = "";
        gate.SearchResults.Clear();
        gate.ShowDropdown = false;
    }

    private void OnGateGroupFocusOut(CapabilityGateRow gate)
    {
        _ = Task.Delay(200).ContinueWith(_ =>
        {
            gate.ShowDropdown = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private sealed class CapabilityGateRow
    {
        public string Capability { get; set; } = "";
        public string GroupId { get; set; } = "";
        public string GroupName { get; set; } = "";
        public bool ShowDropdown { get; set; }
        public List<GroupLookupResult> SearchResults { get; set; } = new();
    }

    // ---- Certificate upload & parsing -----------------------------------

    private async Task OnCertFilesSelected(InputFileChangeEventArgs e)
    {
        _certError = null;
        var maxSize = 50 * 1024; // 50 KB max per cert file
        foreach (var file in e.GetMultipleFiles(100))
        {
            try
            {
                using var ms = new System.IO.MemoryStream();
                await file.OpenReadStream(maxSize).CopyToAsync(ms);
                var bytes = ms.ToArray();

                // Try parse as DER or PEM
                var cert = ParseCertBytes(bytes);
                if (cert is null)
                {
                    _certError = $"File '{file.Name}' non e' un certificato valido.";
                    continue;
                }

                // Avoid duplicates by thumbprint
                if (_parsedCerts.Any(c => c.Thumbprint == cert.Thumbprint))
                    continue;

                _parsedCerts.Add(cert);
            }
            catch (Exception ex)
            {
                _certError = $"Errore nel file '{file.Name}': {ex.Message}";
            }
        }
    }

    private static ParsedCert? ParseCertBytes(byte[] bytes)
    {
        System.Security.Cryptography.X509Certificates.X509Certificate2? x509 = null;
        try
        {
            x509 = System.Security.Cryptography.X509Certificates.X509CertificateLoader.LoadCertificate(bytes);
        }
        catch
        {
            try
            {
                var pem = System.Text.Encoding.ASCII.GetString(bytes);
                x509 = System.Security.Cryptography.X509Certificates.X509Certificate2.CreateFromPem(pem);
            }
            catch { return null; }
        }

        if (x509 is null) return null;

        var isRoot = string.Equals(x509.Subject, x509.Issuer, StringComparison.OrdinalIgnoreCase);
        var b64 = Convert.ToBase64String(x509.RawData);

        return new ParsedCert
        {
            Subject = x509.Subject,
            Issuer = x509.Issuer,
            Thumbprint = x509.Thumbprint,
            Base64 = b64,
            NotAfter = x509.NotAfter,
            IsRoot = isRoot,
        };
    }

    private void TryAddCertFromBase64(string b64, bool forceRoot)
    {
        try
        {
            var bytes = Convert.FromBase64String(b64);
            var x509 = System.Security.Cryptography.X509Certificates.X509CertificateLoader.LoadCertificate(bytes);
            if (_parsedCerts.Any(c => c.Thumbprint == x509.Thumbprint))
                return;

            var isRoot = forceRoot || string.Equals(x509.Subject, x509.Issuer, StringComparison.OrdinalIgnoreCase);
            _parsedCerts.Add(new ParsedCert
            {
                Subject = x509.Subject,
                Issuer = x509.Issuer,
                Thumbprint = x509.Thumbprint,
                Base64 = b64,
                NotAfter = x509.NotAfter,
                IsRoot = isRoot,
            });
        }
        catch { /* skip invalid stored cert */ }
    }

    private void RemoveCert(ParsedCert cert) => _parsedCerts.Remove(cert);

    private sealed class ParsedCert
    {
        public string Subject { get; set; } = "";
        public string Issuer { get; set; } = "";
        public string Thumbprint { get; set; } = "";
        public string Base64 { get; set; } = "";
        public DateTime NotAfter { get; set; }
        public bool IsRoot { get; set; }
        public bool IsExpired => NotAfter < DateTime.UtcNow;
    }
}
