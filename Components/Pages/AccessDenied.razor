@page "/access-denied"
@layout MainLayout
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav

@* Public courtesy page. Two ways to get here:
   - Cookie LoginPath  → user is NOT authenticated (show the login link).
   - Cookie AccessDeniedPath → user IS authenticated but lacks a required app
     role (explain which role is missing and offer account switch).
   Both branches are rendered from a single page so the operator always sees a
   clear explanation rather than a raw 403 or a redirect loop. *@
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Accesso al portale</PageTitle>

<div class="container py-5" style="max-width: 720px;">
    <AuthorizeView>
        <NotAuthorized>
            @* Not signed in. *@
            <h1 class="h3 mb-3">Accesso richiesto</h1>
            <p class="text-muted">
                Per utilizzare <em>Intune Device Actions Portal</em> devi
                autenticarti con il tuo account aziendale (Microsoft Entra ID).
            </p>
            <p>
                Verrai reindirizzato alla pagina di accesso Microsoft. Dopo il
                login tornerai automaticamente alla pagina richiesta.
            </p>
            <a class="btn btn-primary" href="@SignInHref">
                <span class="me-1">🔑</span> Accedi
            </a>
        </NotAuthorized>
        <Authorized>
            @* Signed in but missing the required app role. *@
            <h1 class="h3 text-danger mb-3">Accesso negato</h1>
            <p>
                Sei autenticato come
                <strong>@context.User.Identity?.Name</strong>, ma il tuo account
                non possiede uno dei ruoli applicativi richiesti per accedere a
                questa sezione.
            </p>
            <ul>
                <li><code>Actions.Observer</code> — lettura dashboard e audit trail</li>
                <li><code>Actions.Auditor</code> — lettura + export audit (futuro)</li>
                <li><code>Actions.Operator</code> — gestione delle schedulazioni (wave)</li>
            </ul>
            <p class="text-muted">
                Contatta l'amministratore della app registration
                <em>Intune Device Actions Portal</em> per richiedere
                l'assegnazione del ruolo opportuno. Una volta assegnato, esci e
                accedi di nuovo per aggiornare il token.
            </p>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-primary" href="@SignInHref">
                    Cambia account
                </a>
                <a class="btn btn-outline-secondary"
                   href="MicrosoftIdentity/Account/SignOut">
                    Esci
                </a>
            </div>

            <details class="mt-4">
                <summary class="text-muted" style="cursor:pointer;">
                    Dettagli tecnici del token
                </summary>
                <div class="mt-2 small">
                    @{
                        var oid = context.User.Claims
                            .FirstOrDefault(c => c.Type == "oid"
                                || c.Type.EndsWith("/objectidentifier"))?.Value;
                        var tid = context.User.Claims
                            .FirstOrDefault(c => c.Type == "tid"
                                || c.Type.EndsWith("/tenantid"))?.Value;
                    }
                    <p class="mb-1">
                        Ruoli presenti nel token:
                        @{
                            var roleClaims = context.User.Claims
                                .Where(c => c.Type == "roles"
                                    || c.Type == System.Security.Claims.ClaimTypes.Role)
                                .Select(c => c.Value)
                                .ToList();
                        }
                        @if (roleClaims.Count == 0)
                        {
                            <strong class="text-danger">nessuno</strong>
                            <span> — il token non contiene il claim
                            <code>roles</code>. Esci completamente e accedi di
                            nuovo per rigenerarlo dopo l'assegnazione.</span>
                        }
                        else
                        {
                            <strong>@string.Join(", ", roleClaims)</strong>
                        }
                    </p>
                    <p class="mb-1 text-muted">
                        Tipi di claim nel token:
                        <code>@string.Join(", ",
                            context.User.Claims.Select(c => c.Type).Distinct())</code>
                    </p>
                    <p class="mb-1 text-muted">
                        OID: <code>@(string.IsNullOrWhiteSpace(oid) ? "n/a" : oid)</code>
                        — TID: <code>@(string.IsNullOrWhiteSpace(tid) ? "n/a" : tid)</code>
                    </p>
                </div>
            </details>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    // Build an explicit OIDC sign-in link, preserving the ReturnUrl the cookie
    // middleware appended when it redirected an unauthenticated user here.
    private string SignInHref
    {
        get
        {
            var uri = new Uri(Nav.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers
                .ParseQuery(uri.Query);
            var returnUrl = query.TryGetValue("ReturnUrl", out var r)
                ? r.ToString()
                : "/";
            if (string.IsNullOrWhiteSpace(returnUrl) ||
                !returnUrl.StartsWith('/'))
            {
                returnUrl = "/";
            }
            return "MicrosoftIdentity/Account/SignIn?redirectUri=" +
                Uri.EscapeDataString(returnUrl);
        }
    }
}
