    }

    // ---- Entra group typeahead ------------------------------------------

    private List<GroupLookupResult> _groupSearchResults = new();
    private bool _showGroupDropdown;
    private CancellationTokenSource? _groupSearchCts;

    private async Task OnGroupSearchInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        _edit.EntraGroupDisplay = value;

        _groupSearchCts?.Cancel();
        _groupSearchCts = new CancellationTokenSource();
        var token = _groupSearchCts.Token;

        if (value.Length < 2)
        {
            _groupSearchResults.Clear();
            _showGroupDropdown = false;
            return;
        }

        try { await Task.Delay(300, token); }
        catch (TaskCanceledException) { return; }

        try
        {
            var results = await DeviceLookup.SearchGroupsAsync(value, 10, token);
            if (!token.IsCancellationRequested)
            {
                _groupSearchResults = results.ToList();
                _showGroupDropdown = _groupSearchResults.Count > 0;
            }
        }
        catch (TaskCanceledException) { }
    }

    private void SelectGroup(GroupLookupResult group)
    {
        _edit.EntraGroupId = group.GroupId;
        _edit.EntraGroupDisplay = group.DisplayName;
        _groupSearchResults.Clear();
        _showGroupDropdown = false;
    }

    private void ClearGroup()
    {
        _edit.EntraGroupId = null;
        _edit.EntraGroupDisplay = null;
        _groupSearchResults.Clear();
        _showGroupDropdown = false;
    }

    private void OnGroupSearchFocusOut()
    {
        _ = Task.Delay(200).ContinueWith(_ =>
        {
            _showGroupDropdown = false;
            InvokeAsync(StateHasChanged);
        });
    }
}
