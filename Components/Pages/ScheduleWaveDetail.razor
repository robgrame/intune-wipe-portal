        public string? Description { get; set; }
        public DateTime ScheduledAtLocal { get; set; }
        public string Status { get; set; } = WipeWaveStatus.Scheduled;
        public string? EntraGroupId { get; set; }
        public string? EntraGroupDisplay { get; set; }
    }

    private sealed class MemberDraft
