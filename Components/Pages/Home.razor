@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuditQueryService Audit
@inject CruscottoTelemetryService Cruscotto
@inject CapabilityRegistry CapRegistry
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Action dashboard</PageTitle>

<h1 class="mb-3">Intune device actions dashboard</h1>
<p class="text-muted">
    Ultime 24 ore · refresh ogni 60s · capability:
    <strong>@_capability.DisplayName</strong>
</p>

@if (_tabs is null)
{
    <p><em>Discovering capabilities…</em></p>
}
else
{
    <ul class="nav nav-pills mb-3" role="tablist">
        @foreach (var cap in _tabs)
        {
            var active = ReferenceEquals(cap, _capability) || cap.ActionTypeValue == _capability.ActionTypeValue ? "active" : "";
            <li class="nav-item">
                <button type="button" class="nav-link @active" @onclick="() => SetCapabilityAsync(cap)">
                    @cap.DisplayName
                </button>
            </li>
        }
    </ul>
}

@if (_loadError is not null)
{
    <div class="alert alert-danger">
        Errore caricamento dati: @_loadError
    </div>
}

@* ── Health Banner ── *@
@if (_health is not null)
{
    var bannerCss = _health.OverallStatus switch
    {
        NodeHealth.Green => "alert-success",
        NodeHealth.Yellow => "alert-warning",
        NodeHealth.Red => "alert-danger",
        _ => "alert-secondary"
    };
    var bannerIcon = _health.OverallStatus switch
    {
        NodeHealth.Green => "✅",
        NodeHealth.Yellow => "⚠️",
        NodeHealth.Red => "🚨",
        _ => "❔"
    };
    <div class="alert @bannerCss mb-3 d-flex align-items-center justify-content-between" style="cursor:pointer" @onclick="() => _showHealthDetail = !_showHealthDetail">
        <div>
            <strong>@bannerIcon @_health.StatusLabel</strong>
            @if (_health.Issues.Count > 0)
            {
                <span class="ms-2 text-muted">(@_health.Issues.Count problema/i rilevato/i — clicca per dettagli)</span>
            }
        </div>
        <small class="text-muted">infra health</small>
    </div>
    @if (_showHealthDetail && _health.Issues.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-body p-2">
                <table class="table table-sm mb-0">
                    <thead><tr><th></th><th>Problema</th></tr></thead>
                    <tbody>
                    @foreach (var issue in _health.Issues)
                    {
                        var rowCss = issue.Severity == "critical" ? "table-danger" : issue.Severity == "warning" ? "table-warning" : "";
                        <tr class="@rowCss">
                            <td>@issue.Icon</td>
                            <td>@issue.Message</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@if (_kpis is null)
{
    <p><em>Loading...</em></p>
}
else
{
    @* ── Charts row ── *@
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted text-uppercase small">Esito richieste (24h)</h6>
                    <div style="height:200px; position:relative;">
                        <canvas id="chartOutcome"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted text-uppercase small">Pipeline (24h)</h6>
                    <div style="height:200px; position:relative;">
                        <canvas id="chartPipeline"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Compact KPI cards ── *@
    <div class="row g-2 mb-4">
        @KpiCardCompact("Totali", _kpis.TotalRequests, "primary")
        @KpiCardCompact("Accettate", _kpis.Accepted, "success")
        @KpiCardCompactClickable("Negate", _kpis.Denied, "warning", () => _showDeniedPanel = !_showDeniedPanel)
        @KpiCardCompact("Inviate", _kpis.TotalIssued, "info")
        @KpiCardCompact("Completate", _kpis.ActionCompleted, "success")
        @KpiCardCompactClickable("Fallite", _kpis.ActionFailed, "danger", () => _showFailedPanel = !_showFailedPanel)
        @KpiCardCompact("Transient err", _kpis.TotalTransientErrors, "secondary")
        @KpiCardCompact("Perm. fail", _kpis.TotalPermanentFailures, "danger")
        @KpiCardCompact("Poll timeout", _kpis.ActionPollTimeout, "warning")
        @if (_latency is not null && _latency.SampleCount > 0)
        {
            @KpiCardCompactText("Lat. media", $"{_latency.AvgMinutes:F1}m", "info")
            @KpiCardCompactText("Lat. P95", $"{_latency.P95Minutes:F1}m", "info")
        }
    </div>

    @if (_showDeniedPanel)
    {
        <div class="alert alert-warning mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">🚫 Richieste negate — dettaglio (24h)</h5>
                <button type="button" class="btn-close" @onclick="() => _showDeniedPanel = false"></button>
            </div>
            @if (_deniedDetails is null || _deniedDetails.Count == 0)
            {
                <p class="text-muted mb-0">Nessun evento denied nel periodo.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Timestamp (UTC)</th>
                                <th>Device</th>
                                <th>Capability</th>
                                <th>Motivo</th>
                                <th>Evento</th>
                                <th>Trail</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var d in _deniedDetails)
                        {
                            <tr>
                                <td>@d.Timestamp.UtcDateTime.ToString("u")</td>
                                <td>@(d.DeviceName ?? "—")</td>
                                <td>@(d.ActionType ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(d.Reason))
                                    {
                                        @d.Reason
                                    }
                                    else
                                    {
                                        <code class="text-muted">@FriendlyDenyReason(d.EventName)</code>
                                    }
                                </td>
                                <td><code>@d.EventName</code></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.CorrelationId))
                                    {
                                        <a href="@($"/audit/{d.CorrelationId}")">@d.CorrelationId</a>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    @if (_showFailedPanel)
    {
        <div class="alert alert-danger mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">💀 Azioni fallite — dettaglio (24h)</h5>
                <button type="button" class="btn-close" @onclick="() => _showFailedPanel = false"></button>
            </div>
            @if (_failedDetails is null || _failedDetails.Count == 0)
            {
                <p class="text-muted mb-0">Nessuna azione fallita nel periodo.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Timestamp (UTC)</th>
                                <th>Device</th>
                                <th>Capability</th>
                                <th>Motivo / Eccezione</th>
                                <th>Evento</th>
                                <th>Trail</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var f in _failedDetails)
                        {
                            <tr>
                                <td>@f.Timestamp.UtcDateTime.ToString("u")</td>
                                <td>@(f.DeviceName ?? "—")</td>
                                <td>@(f.ActionType ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(f.Reason))
                                    {
                                        @f.Reason
                                    }
                                    else if (!string.IsNullOrWhiteSpace(f.ExceptionType))
                                    {
                                        <code class="text-muted">@f.ExceptionType</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td><code>@FriendlyFailReason(f.EventName)</code></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(f.CorrelationId))
                                    {
                                        <a href="@($"/audit/{f.CorrelationId}")">@f.CorrelationId</a>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    @if (_capability.IsAll && _kpis.PerCapability.Count > 0)
    {
        <h2 class="h5">Breakdown per capability (24h)</h2>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Capability</th>
                    <th class="text-end">Issued</th>
                    <th class="text-end">Permanent fail</th>
                    <th class="text-end">Transient</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in _kpis.PerCapability)
            {
                <tr>
                    <td>@p.Capability.DisplayName</td>
                    <td class="text-end">@p.Issued</td>
                    <td class="text-end">@p.PermanentFailures</td>
                    <td class="text-end">@p.TransientErrors</td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4">Azioni in-flight</h2>
    @if (_inFlight is null || _inFlight.Count == 0)
    {
        <p class="text-muted">Nessuna azione in attesa di un esito terminale.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Issued (UTC)</th>
                    <th>Capability</th>
                    <th>Device</th>
                    <th>Stato</th>
                    <th class="text-end">Da min.</th>
                    <th>Trail</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var f in _inFlight)
            {
                <tr>
                    <td>@f.IssuedAt.UtcDateTime.ToString("u")</td>
                    <td>@(f.ActionType ?? "-")</td>
                    <td>@(f.DeviceName ?? "-")</td>
                    <td><code>@f.CurrentState</code></td>
                    <td class="text-end">@f.MinutesSinceIssued</td>
                    <td>
                        @if (!string.IsNullOrEmpty(f.CorrelationId))
                        {
                            <a href="@($"/audit/{f.CorrelationId}")">@f.CorrelationId</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4 d-flex align-items-center gap-2">
        🔒 Ledger bloccate
        @if (_stuckEntries is { Count: > 0 })
        {
            <span class="badge bg-danger">@_stuckEntries.Count</span>
        }
    </h2>
    @if (_stuckEntries is null || _stuckEntries.Count == 0)
    {
        <p class="text-muted">Nessuna entry bloccata nel ledger.</p>
    }
    else
    {
        <div class="alert alert-danger">
            <p class="mb-2">
                <strong>Queste azioni sono state emesse ma non hanno mai ricevuto un esito terminale.</strong>
                I device coinvolti non accettano nuove azioni finché le entry non vengono archiviate.
                Causa tipica: storage <code>publicNetworkAccess=Disabled</code> durante il polling.
            </p>
        </div>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Intune Device ID</th>
                    <th>Correlation ID</th>
                    <th>Emessa (UTC)</th>
                    <th class="text-end">Bloccata da</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var s in _stuckEntries)
            {
                <tr>
                    <td><code>@s.IntuneDeviceId</code></td>
                    <td>
                        @if (!string.IsNullOrEmpty(s.CorrelationId))
                        {
                            <a href="@($"/audit/{s.CorrelationId}")">@s.CorrelationId</a>
                        }
                    </td>
                    <td>@s.IssuedAt.UtcDateTime.ToString("u")</td>
                    <td class="text-end">@s.AgeHours.ToString("F1") h</td>
                    <td>
                        @if (_resetInProgress.Contains(s.IntuneDeviceId))
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else if (_resetDone.Contains(s.IntuneDeviceId))
                        {
                            <span class="text-success">✅ Sbloccata</span>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ResetLedgerEntryAsync(s.IntuneDeviceId)">
                                🗑️ Archivia e sblocca
                            </button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (_stuckEntries.Count > 1)
        {
            <button class="btn btn-sm btn-danger" @onclick="ResetAllStuckAsync" disabled="@(_resetAllInProgress)">
                @if (_resetAllInProgress)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                🗑️ Archivia e sblocca tutte (@_stuckEntries.Count)
            </button>
        }
        @if (_resetError is not null)
        {
            <div class="alert alert-warning mt-2">@_resetError</div>
        }
    }

    <h2 class="h5 mt-4">Deny breakdown (24h)</h2>
    @if (_denies is null || _denies.Count == 0)
    {
        <p class="text-muted">Nessun evento denied nel periodo.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead><tr><th>Evento</th><th class="text-end">Conteggio</th></tr></thead>
            <tbody>
            @foreach (var d in _denies)
            {
                <tr><td><code>@d.EventName</code></td><td class="text-end">@d.Count</td></tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4 d-flex justify-content-between align-items-center">
        <span>Cruscotto operativo</span>
        <a class="btn btn-sm btn-outline-secondary" href="/cruscotto" data-enhance-nav="false">Apri vista completa</a>
    </h2>
    <details class="mb-3">
        <summary>Apri il cruscotto dentro la home</summary>
        <div class="mt-2" style="border:1px solid #dee2e6; border-radius:.5rem; overflow:hidden;">
            <iframe
                src="/cruscotto"
                title="Cruscotto operativo"
                loading="lazy"
                style="width:100%; min-height:900px; border:0;"
                referrerpolicy="no-referrer">
            </iframe>
        </div>
    </details>

    <h2 class="h5 mt-4 d-flex justify-content-between align-items-center">
        <span>Ultimi eventi</span>
        <small class="text-muted">ultime 20 entry logiche</small>
    </h2>
    @if (_recent is null || _recent.Count == 0)
    {
        <p class="text-muted">Nessun evento.</p>
    }
    else
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Timestamp (UTC)</th>
                    <th>Evento</th>
                    <th>Capability</th>
                    <th>Device</th>
                    <th>Reason</th>
                    <th>Trail</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var e in _recent)
            {
                <tr>
                    <td>@e.Timestamp.UtcDateTime.ToString("u")</td>
                    <td>
                        @if (e.IsCollapsedGroup)
                        {
                            <details>
                                <summary><code>@e.EventName</code></summary>
                                <div class="small text-muted mt-1">
                                    @e.Reason
                                </div>
                                @if (e.GroupedEvents is { Count: > 0 } grouped)
                                {
                                    <table class="table table-sm mb-0 mt-2">
                                        <thead>
                                            <tr>
                                                <th>Timestamp (UTC)</th>
                                                <th>Reason</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var ge in grouped.Take(25))
                                        {
                                            <tr>
                                                <td>@ge.Timestamp.UtcDateTime.ToString("u")</td>
                                                <td>@(ge.Reason ?? "-")</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                }
                            </details>
                        }
                        else
                        {
                            <code>@e.EventName</code>
                        }
                    </td>
                    <td>@(e.ActionType ?? "-")</td>
                    <td>@(e.DeviceName ?? "-")</td>
                    <td>@(e.Reason ?? "-")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(e.CorrelationId))
                        {
                            <a href="@($"/audit/{e.CorrelationId}")">@e.CorrelationId</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@code {
    private IReadOnlyList<CapabilityDescriptor>? _tabs;
    private CapabilityDescriptor _capability = CapabilityDescriptor.All;
    private KpiSummary? _kpis;
    private IReadOnlyList<DenyBreakdownRow>? _denies;
    private IReadOnlyList<AuditEventRow>? _deniedDetails;
    private IReadOnlyList<AuditEventRow>? _failedDetails;
    private IReadOnlyList<RecentEventDisplayRow>? _recent;
    private IReadOnlyList<InFlightActionRow>? _inFlight;
    private IReadOnlyList<StuckLedgerEntry>? _stuckEntries;
    private HealthSummary? _health;
    private LatencyStats? _latency;
    private string? _loadError;
    private bool _showDeniedPanel;
    private bool _showFailedPanel;
    private bool _showHealthDetail;
    private readonly HashSet<string> _resetInProgress = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _resetDone = new(StringComparer.OrdinalIgnoreCase);
    private bool _resetAllInProgress;
    private string? _resetError;
    private System.Threading.Timer? _timer;
    private bool _chartsRendered;

    protected override async Task OnInitializedAsync()
    {
        _tabs = await CapRegistry.GetCapabilitiesAsync(default);
        _capability = _tabs.FirstOrDefault(c => c.IsAll) ?? CapabilityDescriptor.All;
        await LoadAsync();
        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(LoadAsync);
            await InvokeAsync(StateHasChanged);
            await InvokeAsync(RenderChartsAsync);
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_kpis is not null && !_chartsRendered)
        {
            _chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task SetCapabilityAsync(CapabilityDescriptor cap)
    {
        if (cap.ActionTypeValue == _capability.ActionTypeValue) return;
        _capability = cap;
        _kpis = null; _denies = null; _recent = null; _inFlight = null; _failedDetails = null;
        await LoadAsync();
        await RenderChartsAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var window = TimeSpan.FromHours(24);
            var kpiTask = Audit.GetKpisAsync(window, _capability, default);
            var deniesTask = Audit.GetDenyBreakdownAsync(window, _capability, default);
            var deniedDetailsTask = Audit.GetRecentDeniedEventsAsync(50, window, _capability, default);
            var failedDetailsTask = Audit.GetRecentFailedEventsAsync(50, window, _capability, default);
            var recentTask = Audit.GetRecentEventsAsync(120, window, _capability, default);
            var inFlightTask = Audit.GetInFlightActionsAsync(window, _capability, default);
            var latencyTask = Audit.GetLatencyAsync(window, _capability, default);

            await Task.WhenAll(kpiTask, deniesTask, deniedDetailsTask, failedDetailsTask, recentTask, inFlightTask, latencyTask);

            _kpis = await kpiTask;
            _denies = await deniesTask;
            _deniedDetails = await deniedDetailsTask;
            _failedDetails = await failedDetailsTask;
            var recentRaw = await recentTask;
            _recent = BuildRecentDisplayRows(recentRaw, 20);
            _inFlight = await inFlightTask;
            _latency = await latencyTask;
            _loadError = null;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }

        // Load infra health (independent — non-fatal if it fails)
        try
        {
            _health = await BuildHealthSummaryAsync();
        }
        catch { _health = null; }
    }

    private async Task<HealthSummary> BuildHealthSummaryAsync()
    {
        var snapshot = await Cruscotto.SnapshotAsync(default);
        var issues = new List<HealthIssue>();

        // Populate stuck entries for the management panel
        _stuckEntries = snapshot.Ledger.TopStuck;

        // Check DLQ
        foreach (var q in snapshot.Queues.Where(q => q.DeadLetter > 0))
            issues.Add(new HealthIssue("critical", "💀", $"Coda '{q.Name}' ha {q.DeadLetter} messaggi in Dead Letter Queue"));

        // Check queue backlog
        foreach (var q in snapshot.Queues.Where(q => q.Active >= 20))
            issues.Add(new HealthIssue("warning", "📥", $"Coda '{q.Name}' ha {q.Active} messaggi in attesa — possibile backlog"));

        // Check ledger stuck
        if (snapshot.Ledger.StuckEntries > 0)
            issues.Add(new HealthIssue("warning", "🔒", $"{snapshot.Ledger.StuckEntries} entry nel ledger bloccate da oltre {snapshot.Ledger.GraceHours}h — i device coinvolti non accettano nuove azioni"));

        // Check ledger error
        if (snapshot.Ledger.Error is not null)
            issues.Add(new HealthIssue("critical", "⚠️", $"Ispezione ledger fallita: {snapshot.Ledger.Error}"));

        // Check Function Apps
        foreach (var (role, fa) in snapshot.Diagnostics.FunctionApps)
        {
            if (fa.Health == NodeHealth.Red)
                issues.Add(new HealthIssue("critical", "🔴", $"Function App '{fa.AppName}' in stato critico: {fa.LastError ?? "nessun dettaglio"}"));
            else if (fa.Health == NodeHealth.Yellow)
                issues.Add(new HealthIssue("warning", "🟡", $"Function App '{fa.AppName}' degradata (errori recenti: {fa.Failures30m})"));
        }

        // Check poller
        if (snapshot.Diagnostics.PollerHealth == NodeHealth.Red)
            issues.Add(new HealthIssue("critical", "⏱️", "Status poller fermo — nessuna invocazione recente"));
        else if (snapshot.Diagnostics.PollerHealth == NodeHealth.Yellow)
            issues.Add(new HealthIssue("warning", "⏱️", "Status poller rallentato"));

        // Check denied (last hour)
        if (snapshot.DeniedRequests.Count >= 5)
            issues.Add(new HealthIssue("warning", "🚫", $"{snapshot.DeniedRequests.Count} richieste negate nell'ultima ora — verificare autorizzazioni dispositivi"));

        // Diagnostics issues
        foreach (var d in snapshot.Diagnostics.Issues)
            issues.Add(new HealthIssue("info", "ℹ️", d));

        var overall = issues.Any(i => i.Severity == "critical") ? NodeHealth.Red
                    : issues.Any(i => i.Severity == "warning") ? NodeHealth.Yellow
                    : NodeHealth.Green;

        var label = overall switch
        {
            NodeHealth.Green => "Infrastruttura operativa — tutto regolare",
            NodeHealth.Yellow => "Attenzione — problemi minori rilevati",
            NodeHealth.Red => "Critico — intervento richiesto",
            _ => "Stato sconosciuto"
        };

        return new HealthSummary(overall, label, issues);
    }

    private static RenderFragment KpiCardCompact(string title, long value, string color) => builder =>
    {
        builder.AddMarkupContent(0, $@"
            <div class='col-lg-2 col-md-3 col-4'>
                <div class='card border-start border-4 border-{color} h-100 shadow-sm'>
                    <div class='card-body py-2 px-3'>
                        <div class='text-muted small text-uppercase' style='font-size:.7rem;'>{title}</div>
                        <div class='fw-bold fs-5'>{value}</div>
                    </div>
                </div>
            </div>");
    };

    private RenderFragment KpiCardCompactClickable(string title, long value, string color, Action onClick) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "col-lg-2 col-md-3 col-4");
        builder.AddAttribute(2, "style", "cursor:pointer;");
