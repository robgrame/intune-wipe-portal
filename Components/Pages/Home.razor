@page "/"
@rendermode InteractiveServer
@inject AuditQueryService Audit
@inject CapabilityRegistry CapRegistry
@implements IDisposable

<PageTitle>Action dashboard</PageTitle>

<h1 class="mb-3">Intune device actions dashboard</h1>
<p class="text-muted">
    Ultime 24 ore · refresh ogni 60s · capability:
    <strong>@_capability.DisplayName</strong>
</p>

@if (_tabs is null)
{
    <p><em>Discovering capabilities…</em></p>
}
else
{
    <ul class="nav nav-pills mb-3" role="tablist">
        @foreach (var cap in _tabs)
        {
            var active = ReferenceEquals(cap, _capability) || cap.ActionTypeValue == _capability.ActionTypeValue ? "active" : "";
            <li class="nav-item">
                <button type="button" class="nav-link @active" @onclick="() => SetCapabilityAsync(cap)">
                    @cap.DisplayName
                </button>
            </li>
        }
    </ul>
}

@if (_loadError is not null)
{
    <div class="alert alert-danger">
        Errore caricamento dati: @_loadError
    </div>
}

@if (_kpis is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row g-3 mb-4">
        @KpiCard("Richieste totali", _kpis.TotalRequests, "primary")
        @KpiCard("Accettate", _kpis.Accepted, "success")
        @KpiCardClickable("Negate", _kpis.Denied, "warning", () => _showDeniedPanel = !_showDeniedPanel)
        @KpiCard("Inviate", _kpis.TotalIssued, "info")
        @KpiCard("Completate", _kpis.ActionCompleted, "success")
        @KpiCard("Fallite", _kpis.ActionFailed, "danger")
    </div>

    <div class="row g-3 mb-4">
        @KpiCard("Errori transient", _kpis.TotalTransientErrors, "secondary")
        @KpiCard("Fail permanenti", _kpis.TotalPermanentFailures, "danger")
        @KpiCard("Poll timeout", _kpis.ActionPollTimeout, "warning")
    </div>

    @if (_showDeniedPanel)
    {
        <div class="alert alert-warning mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">🚫 Richieste negate — dettaglio (24h)</h5>
                <button type="button" class="btn-close" @onclick="() => _showDeniedPanel = false"></button>
            </div>
            @if (_deniedDetails is null || _deniedDetails.Count == 0)
            {
                <p class="text-muted mb-0">Nessun evento denied nel periodo.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Timestamp (UTC)</th>
                                <th>Device</th>
                                <th>Capability</th>
                                <th>Motivo</th>
                                <th>Evento</th>
                                <th>Trail</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var d in _deniedDetails)
                        {
                            <tr>
                                <td>@d.Timestamp.UtcDateTime.ToString("u")</td>
                                <td>@(d.DeviceName ?? "—")</td>
                                <td>@(d.ActionType ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(d.Reason))
                                    {
                                        @d.Reason
                                    }
                                    else
                                    {
                                        <code class="text-muted">@FriendlyDenyReason(d.EventName)</code>
                                    }
                                </td>
                                <td><code>@d.EventName</code></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.CorrelationId))
                                    {
                                        <a href="@($"/audit/{d.CorrelationId}")">@d.CorrelationId</a>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    @if (_capability.IsAll && _kpis.PerCapability.Count > 0)
    {
        <h2 class="h5">Breakdown per capability (24h)</h2>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Capability</th>
                    <th class="text-end">Issued</th>
                    <th class="text-end">Permanent fail</th>
                    <th class="text-end">Transient</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in _kpis.PerCapability)
            {
                <tr>
                    <td>@p.Capability.DisplayName</td>
                    <td class="text-end">@p.Issued</td>
                    <td class="text-end">@p.PermanentFailures</td>
                    <td class="text-end">@p.TransientErrors</td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4">Azioni in-flight</h2>
    @if (_inFlight is null || _inFlight.Count == 0)
    {
        <p class="text-muted">Nessuna azione in attesa di un esito terminale.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Issued (UTC)</th>
                    <th>Capability</th>
                    <th>Device</th>
                    <th>Stato</th>
                    <th class="text-end">Da min.</th>
                    <th>Trail</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var f in _inFlight)
            {
                <tr>
                    <td>@f.IssuedAt.UtcDateTime.ToString("u")</td>
                    <td>@(f.ActionType ?? "-")</td>
                    <td>@(f.DeviceName ?? "-")</td>
                    <td><code>@f.CurrentState</code></td>
                    <td class="text-end">@f.MinutesSinceIssued</td>
                    <td>
                        @if (!string.IsNullOrEmpty(f.CorrelationId))
                        {
                            <a href="@($"/audit/{f.CorrelationId}")">@f.CorrelationId</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4">Deny breakdown (24h)</h2>
    @if (_denies is null || _denies.Count == 0)
    {
        <p class="text-muted">Nessun evento denied nel periodo.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead><tr><th>Evento</th><th class="text-end">Conteggio</th></tr></thead>
            <tbody>
            @foreach (var d in _denies)
            {
                <tr><td><code>@d.EventName</code></td><td class="text-end">@d.Count</td></tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4 d-flex justify-content-between align-items-center">
        <span>Cruscotto operativo</span>
        <a class="btn btn-sm btn-outline-secondary" href="/cruscotto" data-enhance-nav="false">Apri vista completa</a>
    </h2>
    <details class="mb-3">
        <summary>Apri il cruscotto dentro la home</summary>
        <div class="mt-2" style="border:1px solid #dee2e6; border-radius:.5rem; overflow:hidden;">
            <iframe
                src="/cruscotto"
                title="Cruscotto operativo"
                loading="lazy"
                style="width:100%; min-height:900px; border:0;"
                referrerpolicy="no-referrer">
            </iframe>
        </div>
    </details>

    <h2 class="h5 mt-4 d-flex justify-content-between align-items-center">
        <span>Ultimi eventi</span>
        <small class="text-muted">ultime 20 entry logiche</small>
    </h2>
    @if (_recent is null || _recent.Count == 0)
    {
        <p class="text-muted">Nessun evento.</p>
    }
    else
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Timestamp (UTC)</th>
                    <th>Evento</th>
                    <th>Capability</th>
                    <th>Device</th>
                    <th>Reason</th>
                    <th>Trail</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var e in _recent)
            {
                <tr>
                    <td>@e.Timestamp.UtcDateTime.ToString("u")</td>
                    <td>
                        @if (e.IsCollapsedGroup)
                        {
                            <details>
                                <summary><code>@e.EventName</code></summary>
                                <div class="small text-muted mt-1">
                                    @e.Reason
                                </div>
                                @if (e.GroupedEvents is { Count: > 0 } grouped)
                                {
                                    <table class="table table-sm mb-0 mt-2">
                                        <thead>
                                            <tr>
                                                <th>Timestamp (UTC)</th>
                                                <th>Reason</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var ge in grouped.Take(25))
                                        {
                                            <tr>
                                                <td>@ge.Timestamp.UtcDateTime.ToString("u")</td>
                                                <td>@(ge.Reason ?? "-")</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                }
                            </details>
                        }
                        else
                        {
                            <code>@e.EventName</code>
                        }
                    </td>
                    <td>@(e.ActionType ?? "-")</td>
                    <td>@(e.DeviceName ?? "-")</td>
                    <td>@(e.Reason ?? "-")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(e.CorrelationId))
                        {
                            <a href="@($"/audit/{e.CorrelationId}")">@e.CorrelationId</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@code {
    private IReadOnlyList<CapabilityDescriptor>? _tabs;
    private CapabilityDescriptor _capability = CapabilityDescriptor.All;
    private KpiSummary? _kpis;
    private IReadOnlyList<DenyBreakdownRow>? _denies;
    private IReadOnlyList<AuditEventRow>? _deniedDetails;
    private IReadOnlyList<RecentEventDisplayRow>? _recent;
    private IReadOnlyList<InFlightActionRow>? _inFlight;
    private string? _loadError;
    private bool _showDeniedPanel;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        _tabs = await CapRegistry.GetCapabilitiesAsync(default);
        // Pin the local _capability reference to the All instance returned by
        // the registry so reference-equality comparisons in the tab loop work.
        _capability = _tabs.FirstOrDefault(c => c.IsAll) ?? CapabilityDescriptor.All;
        await LoadAsync();
        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(LoadAsync);
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private async Task SetCapabilityAsync(CapabilityDescriptor cap)
    {
        if (cap.ActionTypeValue == _capability.ActionTypeValue) return;
        _capability = cap;
        _kpis = null; _denies = null; _recent = null; _inFlight = null;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var window = TimeSpan.FromHours(24);
            _kpis     = await Audit.GetKpisAsync(window, _capability, default);
            _denies   = await Audit.GetDenyBreakdownAsync(window, _capability, default);
            _deniedDetails = await Audit.GetRecentDeniedEventsAsync(50, window, _capability, default);
            var recentRaw = await Audit.GetRecentEventsAsync(120, window, _capability, default);
            _recent   = BuildRecentDisplayRows(recentRaw, 20);
            _inFlight = await Audit.GetInFlightActionsAsync(window, _capability, default);
            _loadError = null;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private static RenderFragment KpiCard(string title, long value, string color) => builder =>
    {
        builder.AddMarkupContent(0, $@"
            <div class='col-md-2 col-6'>
                <div class='card text-bg-{color} h-100'>
                    <div class='card-body'>
                        <div class='small text-uppercase'>{title}</div>
                        <div class='display-6'>{value}</div>
                    </div>
                </div>
            </div>");
    };

    private RenderFragment KpiCardClickable(string title, long value, string color, Action onClick) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "col-md-2 col-6");
        builder.AddAttribute(2, "style", "cursor:pointer;");
        builder.AddAttribute(3, "title", "Clicca per vedere i dettagli");
        builder.AddAttribute(4, "onclick", Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, onClick));

        builder.AddMarkupContent(5, $@"
            <div class='card text-bg-{color} h-100' style='border:2px dashed rgba(0,0,0,0.2);'>
                <div class='card-body'>
                    <div class='small text-uppercase'>{title} 🔍</div>
                    <div class='display-6'>{value}</div>
                </div>
            </div>");

        builder.CloseElement();
    };

    private static string FriendlyDenyReason(string eventName) => eventName switch
    {
        var e when e.Contains("not-in-allowed-group") => "Device non nel gruppo autorizzato",
        var e when e.Contains("group-check-failed") => "Verifica gruppo fallita",
        var e when e.Contains("not-in-entra") => "Device non registrato in Entra ID",
        var e when e.Contains("ownership-mismatch") => "Device non appartiene all'utente",
        var e when e.Contains("rate-limited") => "Rate limit superato",
        var e when e.Contains("device-resolve-failed") => "Risoluzione device fallita",
        var e when e.Contains("managed-device-resolve-failed") => "Device gestito non trovato",
        var e when e.Contains("already-issued") => "Azione già emessa",
        var e when e.Contains("in-progress-elsewhere") => "Azione già in corso",
        var e when e.Contains("missing-hardware-hash") => "Hardware hash mancante",
        var e when e.Contains("missing-serial") => "Seriale mancante",
        var e when e.Contains("name-collision") => "Collisione nome device",
        _ => eventName
    };

    private static IReadOnlyList<RecentEventDisplayRow> BuildRecentDisplayRows(IReadOnlyList<AuditEventRow> recentRaw, int take)
    {
        var rows = new List<RecentEventDisplayRow>(recentRaw.Count);
        var groupedKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        var stateObservedGroups = recentRaw
            .Where(e => e.EventName == "action.state-observed")
            .GroupBy(StateObservedGroupKey)
            .Where(g => g.Count() > 1);

        foreach (var group in stateObservedGroups)
        {
            var events = group.OrderByDescending(e => e.Timestamp).ToArray();
            groupedKeys.Add(group.Key);

            var newest = events[0];
            var oldest = events[^1];
            var summary = $"{events.Length} osservazioni stato tra {oldest.Timestamp.UtcDateTime:u} e {newest.Timestamp.UtcDateTime:u}";

            rows.Add(new RecentEventDisplayRow(
                Timestamp: newest.Timestamp,
                EventName: $"action.state-observed × {events.Length}",
                CorrelationId: newest.CorrelationId,
                ActionType: newest.ActionType,
                DeviceName: newest.DeviceName,
                Reason: summary,
                IsCollapsedGroup: true,
                GroupedEvents: events));
        }

        foreach (var e in recentRaw)
        {
            if (e.EventName == "action.state-observed" && groupedKeys.Contains(StateObservedGroupKey(e)))
                continue;

            rows.Add(new RecentEventDisplayRow(
                Timestamp: e.Timestamp,
                EventName: e.EventName,
                CorrelationId: e.CorrelationId,
                ActionType: e.ActionType,
                DeviceName: e.DeviceName,
                Reason: e.Reason,
                IsCollapsedGroup: false,
                GroupedEvents: null));
        }

        return rows
            .OrderByDescending(e => e.Timestamp)
            .Take(take)
            .ToArray();
    }

    private static string StateObservedGroupKey(AuditEventRow e)
    {
        if (!string.IsNullOrWhiteSpace(e.CorrelationId))
            return $"corr:{e.CorrelationId}";

        if (!string.IsNullOrWhiteSpace(e.IntuneDeviceId))
            return $"intune:{e.IntuneDeviceId}";

        return $"device:{e.DeviceName ?? "-"}|action:{e.ActionType ?? "-"}";
    }

    private sealed record RecentEventDisplayRow(
        DateTimeOffset Timestamp,
        string EventName,
        string CorrelationId,
        string? ActionType,
        string? DeviceName,
        string? Reason,
        bool IsCollapsedGroup,
        IReadOnlyList<AuditEventRow>? GroupedEvents);

    public void Dispose() => _timer?.Dispose();
}
