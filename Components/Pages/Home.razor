@page "/"
@rendermode InteractiveServer
@inject AuditQueryService Audit
@implements IDisposable

<PageTitle>Action dashboard</PageTitle>

<h1 class="mb-3">Intune device actions dashboard</h1>
<p class="text-muted">
    Ultime 24 ore · refresh ogni 60s · capability:
    <strong>@_capability.DisplayName()</strong>
</p>

<ul class="nav nav-pills mb-3" role="tablist">
    @foreach (var cap in _tabs)
    {
        var active = cap == _capability ? "active" : "";
        <li class="nav-item">
            <button type="button" class="nav-link @active" @onclick="() => SetCapabilityAsync(cap)">
                @cap.DisplayName()
            </button>
        </li>
    }
</ul>

@if (_loadError is not null)
{
    <div class="alert alert-danger">
        Errore caricamento dati: @_loadError
    </div>
}

@if (_kpis is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row g-3 mb-4">
        @KpiCard("Richieste totali", _kpis.TotalRequests, "primary")
        @KpiCard("Accettate", _kpis.Accepted, "success")
        @KpiCard("Negate", _kpis.Denied, "warning")
        @KpiCard("Inviate (Graph)", _kpis.TotalIssued, "info")
        @KpiCard("Completate", _kpis.ActionCompleted, "success")
        @KpiCard("Fallite", _kpis.ActionFailed, "danger")
    </div>

    <div class="row g-3 mb-4">
        @KpiCard("Errori transient", _kpis.TotalTransientErrors, "secondary")
        @KpiCard("Fail permanenti", _kpis.TotalPermanentFailures, "danger")
        @KpiCard("Poll timeout", _kpis.ActionPollTimeout, "warning")
    </div>

    @if (_capability == ActionCapability.All && _kpis.PerCapability.Count > 0)
    {
        <h2 class="h5">Breakdown per capability (24h)</h2>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Capability</th>
                    <th class="text-end">Issued</th>
                    <th class="text-end">Permanent fail</th>
                    <th class="text-end">Transient</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in _kpis.PerCapability)
            {
                <tr>
                    <td>@p.Capability.DisplayName()</td>
                    <td class="text-end">@p.Issued</td>
                    <td class="text-end">@p.PermanentFailures</td>
                    <td class="text-end">@p.TransientErrors</td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4">Azioni in-flight</h2>
    @if (_inFlight is null || _inFlight.Count == 0)
    {
        <p class="text-muted">Nessuna azione in attesa di un esito terminale.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Issued (UTC)</th>
                    <th>Capability</th>
                    <th>Device</th>
                    <th>Stato</th>
                    <th class="text-end">Da min.</th>
                    <th>Trail</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var f in _inFlight)
            {
                <tr>
                    <td>@f.IssuedAt.UtcDateTime.ToString("u")</td>
                    <td>@(f.ActionType ?? "-")</td>
                    <td>@(f.DeviceName ?? "-")</td>
                    <td><code>@f.CurrentState</code></td>
                    <td class="text-end">@f.MinutesSinceIssued</td>
                    <td>
                        @if (!string.IsNullOrEmpty(f.CorrelationId))
                        {
                            <a href="@($"/audit/{f.CorrelationId}")">@f.CorrelationId</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4">Deny breakdown (24h)</h2>
    @if (_denies is null || _denies.Count == 0)
    {
        <p class="text-muted">Nessun evento denied nel periodo.</p>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead><tr><th>Evento</th><th class="text-end">Conteggio</th></tr></thead>
            <tbody>
            @foreach (var d in _denies)
            {
                <tr><td><code>@d.EventName</code></td><td class="text-end">@d.Count</td></tr>
            }
            </tbody>
        </table>
    }

    <h2 class="h5 mt-4">Ultimi eventi</h2>
    @if (_recent is null || _recent.Count == 0)
    {
        <p class="text-muted">Nessun evento.</p>
    }
    else
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Timestamp (UTC)</th>
                    <th>Evento</th>
                    <th>Capability</th>
                    <th>Device</th>
                    <th>Reason</th>
                    <th>Trail</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var e in _recent)
            {
                <tr>
                    <td>@e.Timestamp.UtcDateTime.ToString("u")</td>
                    <td><code>@e.EventName</code></td>
                    <td>@(e.ActionType ?? "-")</td>
                    <td>@(e.DeviceName ?? "-")</td>
                    <td>@(e.Reason ?? "-")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(e.CorrelationId))
                        {
                            <a href="@($"/audit/{e.CorrelationId}")">@e.CorrelationId</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@code {
    private static readonly ActionCapability[] _tabs = new[]
    {
        ActionCapability.All,
        ActionCapability.Wipe,
        ActionCapability.Autopilot,
        ActionCapability.BitLocker,
    };

    private ActionCapability _capability = ActionCapability.All;
    private KpiSummary? _kpis;
    private IReadOnlyList<DenyBreakdownRow>? _denies;
    private IReadOnlyList<AuditEventRow>? _recent;
    private IReadOnlyList<InFlightActionRow>? _inFlight;
    private string? _loadError;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(LoadAsync);
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private async Task SetCapabilityAsync(ActionCapability cap)
    {
        if (cap == _capability) return;
        _capability = cap;
        _kpis = null; _denies = null; _recent = null; _inFlight = null;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var window = TimeSpan.FromHours(24);
            _kpis     = await Audit.GetKpisAsync(window, _capability, default);
            _denies   = await Audit.GetDenyBreakdownAsync(window, _capability, default);
            _recent   = await Audit.GetRecentEventsAsync(100, window, _capability, default);
            _inFlight = await Audit.GetInFlightActionsAsync(window, _capability, default);
            _loadError = null;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private static RenderFragment KpiCard(string title, long value, string color) => builder =>
    {
        builder.AddMarkupContent(0, $@"
            <div class='col-md-2 col-6'>
                <div class='card text-bg-{color} h-100'>
                    <div class='card-body'>
                        <div class='small text-uppercase'>{title}</div>
                        <div class='display-6'>{value}</div>
                    </div>
                </div>
            </div>");
    };

    public void Dispose() => _timer?.Dispose();
}
