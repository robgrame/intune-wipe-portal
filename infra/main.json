{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "5404028493903919623"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "intwipe",
      "minLength": 3,
      "maxLength": 12
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing Log Analytics workspace that hosts the device-actions audit events (created by intune-device-actions)."
      }
    },
    "entraTenantId": {
      "type": "string",
      "defaultValue": "[subscription().tenantId]",
      "metadata": {
        "description": "Entra ID tenant id for OIDC sign-in."
      }
    },
    "entraClientId": {
      "type": "string",
      "metadata": {
        "description": "App Registration ClientId for the portal (created by infra/entra/create-app-registration.ps1)."
      }
    },
    "entraDomain": {
      "type": "string",
      "metadata": {
        "description": "Verified domain of the tenant, e.g. contoso.onmicrosoft.com."
      }
    },
    "entraClientSecret": {
      "type": "securestring",
      "metadata": {
        "description": "Client secret for the portal app registration. Pass via Key Vault reference in production, e.g. @Microsoft.KeyVault(SecretUri=...)."
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "B2",
        "P0v3",
        "P1v3"
      ],
      "metadata": {
        "description": "App Service Plan SKU. B1 for dev; P0v3 or P1v3 for prod."
      }
    },
    "httpsOnly": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Run with HTTPS-only enforcement."
      }
    },
    "nameSuffix": {
      "type": "string",
      "defaultValue": "[uniqueString(resourceGroup().id)]",
      "maxLength": 13,
      "metadata": {
        "description": "Optional suffix appended to every resource name to keep them globally unique. Defaults to uniqueString(resourceGroup().id) for back-compat. Pass an empty string to deploy without any suffix (resource names will be e.g. <namePrefix>-portal). Must be lowercase alphanumeric."
      }
    },
    "serviceBusFullyQualifiedNamespace": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Fully-qualified Service Bus namespace hosting the action queues (e.g. idactions-sb-dev.servicebus.windows.net). Required by the cruscotto to read queue runtime properties."
      }
    },
    "serviceBusNamespaceName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the existing Service Bus namespace (in the same RG). Used to scope the data-owner role assignment. Leave empty to derive from <namePrefix>-sb<sep><suffix>."
      }
    },
    "ledgerStorageAccountName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the existing storage account that holds the action-ledger container (Proc storage). Leave empty to derive from <namePrefix>stproc<suffix> (no separator, no hyphens — storage account naming)."
      }
    },
    "ledgerContainerName": {
      "type": "string",
      "defaultValue": "action-ledger",
      "metadata": {
        "description": "Container name on ledgerStorageAccountName that holds the per-device ledger JSON blobs."
      }
    },
    "appConfigEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Endpoint of the Azure App Configuration store used by the API. The portal uses this to manage operational settings. Leave empty to disable the Configuration page."
      }
    },
    "wipeScheduleStorageAccount": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the storage account hosting the wipe schedule tables (wipeschedulewaves, wipeschedulemembers). Usually the Web role storage account."
      }
    },
    "appInsightsName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Name of the existing App Insights resource (created by intune-device-actions). Leave empty to skip AI instrumentation."
      }
    }
  },
  "variables": {
    "suffix": "[parameters('nameSuffix')]",
    "sep": "[if(empty(variables('suffix')), '', '-')]",
    "planName": "[toLower(format('{0}-plan-portal{1}{2}', parameters('namePrefix'), variables('sep'), variables('suffix')))]",
    "webAppName": "[toLower(format('{0}-portal{1}{2}', parameters('namePrefix'), variables('sep'), variables('suffix')))]",
    "uamiName": "[toLower(format('{0}-uami-portal{1}{2}', parameters('namePrefix'), variables('sep'), variables('suffix')))]",
    "sbNsResolved": "[if(empty(parameters('serviceBusNamespaceName')), toLower(format('{0}-sb{1}{2}', parameters('namePrefix'), variables('sep'), variables('suffix'))), parameters('serviceBusNamespaceName'))]",
    "sbFqdnResolved": "[if(empty(parameters('serviceBusFullyQualifiedNamespace')), format('{0}.servicebus.windows.net', variables('sbNsResolved')), parameters('serviceBusFullyQualifiedNamespace'))]",
    "ledgerAcctResolved": "[if(empty(parameters('ledgerStorageAccountName')), toLower(format('{0}stp{1}', parameters('namePrefix'), variables('suffix'))), parameters('ledgerStorageAccountName'))]",
    "roleLogAnalyticsReader": "73c42c96-874c-492b-b04d-ab87d138a893",
    "roleStorageBlobDataReader": "2a2b9908-6ea1-4ae2-8e65-a410df84e7d1",
    "roleServiceBusDataOwner": "090c5cfd-751d-490a-894a-3ce6f1109419"
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[variables('uamiName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]",
      "name": "[guid(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), variables('roleLogAnalyticsReader'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleLogAnalyticsReader'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ServiceBus/namespaces', variables('sbNsResolved'))]",
      "name": "[guid(resourceId('Microsoft.ServiceBus/namespaces', variables('sbNsResolved')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), variables('roleServiceBusDataOwner'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleServiceBusDataOwner'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('ledgerAcctResolved'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('ledgerAcctResolved')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), variables('roleStorageBlobDataReader'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleStorageBlobDataReader'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('appServicePlanSku')]"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')))]": {}
        }
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": "[parameters('httpsOnly')]",
        "keyVaultReferenceIdentity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]",
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|10.0",
          "minTlsVersion": "1.2",
          "http20Enabled": true,
          "ftpsState": "Disabled",
          "alwaysOn": "[not(equals(parameters('appServicePlanSku'), 'B1'))]",
          "use32BitWorkerProcess": false,
          "appSettings": "[flatten(createArray(createArray(createObject('name', 'AZURE_CLIENT_ID', 'value', reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').clientId), createObject('name', 'Monitor__WorkspaceId', 'value', reference(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2023-09-01').customerId), createObject('name', 'AzureAd__Instance', 'value', 'https://login.microsoftonline.com/'), createObject('name', 'AzureAd__Domain', 'value', parameters('entraDomain')), createObject('name', 'AzureAd__TenantId', 'value', parameters('entraTenantId')), createObject('name', 'AzureAd__ClientId', 'value', parameters('entraClientId')), createObject('name', 'AzureAd__ClientSecret', 'value', parameters('entraClientSecret')), createObject('name', 'AzureAd__CallbackPath', 'value', '/signin-oidc'), createObject('name', 'AzureAd__SignedOutCallbackPath', 'value', '/signout-callback-oidc'), createObject('name', 'ASPNETCORE_FORWARDEDHEADERS_ENABLED', 'value', 'true'), createObject('name', 'WEBSITE_RUN_FROM_PACKAGE', 'value', '1'), createObject('name', 'Cruscotto__ServiceBusFullyQualifiedNamespace', 'value', variables('sbFqdnResolved')), createObject('name', 'Cruscotto__LedgerStorageAccount', 'value', variables('ledgerAcctResolved')), createObject('name', 'Cruscotto__LedgerContainer', 'value', parameters('ledgerContainerName')), createObject('name', 'AppConfig__Endpoint', 'value', parameters('appConfigEndpoint')), createObject('name', 'WipeSchedule__StorageAccountName', 'value', parameters('wipeScheduleStorageAccount'))), if(empty(parameters('appInsightsName')), createArray(), createArray(createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'value', reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').ConnectionString), createObject('name', 'ASPNETCORE_DETAILEDERRORS', 'value', 'true')))))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
      ]
    }
  ],
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "webAppHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01').defaultHostName]"
    },
    "uamiClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').clientId]"
    },
    "uamiPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]"
    },
    "workspaceCustomerId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2023-09-01').customerId]"
    }
  }
}